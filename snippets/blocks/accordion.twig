{#
  accordion.twig — Block dispatcher.

  Reads the `style` field set in the Panel and delegates rendering to the
  appropriate variant template. Each variant independently embeds the shared
  base layout (_accordion_base.twig) and overrides only its own blocks.

  Adding a new visual variant requires only:
    1. A new option value in blueprints/blocks/accordion.yml (style field).
    2. A new embed file in snippets/blocks/  (e.g. accordion_minimal.twig).
    3. A new branch in the conditional below.
  No changes to _accordion_base.twig, accordion.js, or _accordion.scss.
#}

{% set style = block.style.value %}

{% if style == 'with-images' %}
	{% include '@ui/accordion_rich.twig' %}
{% else %}
	{% include '@ui/accordion_simple.twig' %}
{% endif %}
