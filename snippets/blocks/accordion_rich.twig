{#
  accordion_rich.twig — Accordion variant with optional header image and icon.

  Overrides:
    item_header  → optional <img>, title text, and a decorative inline icon.
    item_content → extra wrapper div with BEM modifier for styled background.

  The JS layer is completely unaware of this additional markup. It continues
  to operate solely on [data-accordion-trigger] and [data-accordion-panel].
#}

{% set _wrapper_id = block.html_id.isNotEmpty ? block.html_id.value : 'accordion' %}
{% set _extra_class = block.css_classes.value %}

{% embed '@ui/_accordion_base.twig'
	with {
		items: block.items.toStructure(),
		wrapper_id: _wrapper_id,
		extra_class: _extra_class ~ ' accordion--rich'
	}
%}
	{% block item_header %}
		{% set cover = item.image.toFile %}
		{% if cover %}
			<img class="accordion__image" src="{{ cover.url }}" alt="{{ cover.alt }}" width="{{ cover.width }}" height="{{ cover.height }}" loading="lazy" />
		{% endif %}

		<span class="accordion__trigger-label">{{ item.title.value }}</span>
	{% endblock %}
{% endembed %}
