{#
  kui-select.twig — Block dispatcher.

  Reads the `style` field set in the Panel and delegates rendering to the
  correct variant template. Each variant independently embeds the shared base
  layout (_select_base.twig) and overrides only its own item_list block.

  Project overrides: place a file at site/snippets/ui/kui-select_<style>.twig
  and it will be used automatically without modifying this plugin.
#}

{% set style = block.style.value ? : 'simple' %}
{% include ['@ui/kui-select_' ~ style ~ '.twig', '@ui/kui-select_simple.twig'] %}
