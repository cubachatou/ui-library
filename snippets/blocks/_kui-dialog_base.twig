{#
  _kui-dialog_base.twig — Base dialog layout (internal partial).

  Expected variables (passed via {% embed %} with {...}):
    wrapper_id        {string}  HTML id for the root wrapper element.
    extra_class       {string}  Extra CSS classes appended to the <dialog> element.
    trigger_label     {string}  Text label for the trigger button.
    dialog_title      {string}  Visible title inside the dialog header.
    dialog_description {string} Supporting text below the title.
    close_on_backdrop {bool}    Whether clicking the backdrop closes the dialog.

  Overridable blocks:
    {% block dialog_close_button %} — The × close button. Empty this block to suppress it.
    {% block dialog_body %}         — Main scrollable body region.
    {% block dialog_footer %}       — Footer action region.

  JS hook attributes (never remove or rename):
    data-kui-dialog           — Root wrapper element.
    data-kui-dialog-trigger   — <button> that opens the dialog.
    data-kui-dialog-panel     — The <dialog> element itself.
    data-kui-dialog-close     — Any element that closes the dialog on click.
    data-kui-dialog-options   — JSON configuration forwarded to dialog.js.
#}

{% set _id          = wrapper_id is defined and wrapper_id ? wrapper_id : 'dialog' %}
{% set _extra       = extra_class is defined and extra_class ? ' ' ~ extra_class : '' %}
{% set _backdrop    = close_on_backdrop is defined ? close_on_backdrop : true %}
{% set _title       = dialog_title is defined ? dialog_title : '' %}
{% set _description = dialog_description is defined ? dialog_description : '' %}
{% set _trigger     = trigger_label is defined ? trigger_label : 'Open' %}

{% set _title_id = _id ~ '__title' %}
{% set _desc_id  = _id ~ '__description' %}

<div
	class="kui-dialog__wrap"
	id="{{ _id }}"
	data-kui-dialog
	data-kui-dialog-options='{{ {"closeOnBackdrop": _backdrop}|json_encode }}'
>
	{# ── Trigger ─────────────────────────────────────────────────────────── #}
	<button
		class="kui-dialog__trigger kui-button kui-button--default"
		type="button"
		aria-haspopup="dialog"
		data-kui-dialog-trigger
	>
		{{- _trigger -}}
	</button>

	{# ── Dialog panel ────────────────────────────────────────────────────── #}
	<dialog
		class="kui-dialog{{ _extra }}"
		aria-labelledby="{{ _title_id }}"
		{% if _description %} aria-describedby="{{ _desc_id }}"{% endif %}
		data-kui-dialog-panel
	>
		<div class="kui-dialog__inner">

			{# ── Close button — overridable to empty in no-close variant ── #}
			{% block dialog_close_button %}
				<button
					class="kui-dialog__close"
					type="button"
					aria-label="Close dialog"
					data-kui-dialog-close
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
						<path d="M18 6 6 18M6 6l12 12"/>
					</svg>
				</button>
			{% endblock %}

			{# ── Header ──────────────────────────────────────────────────── #}
			<div class="kui-dialog__header">
				<h2 class="kui-dialog__title" id="{{ _title_id }}">{{ _title }}</h2>
				{% if _description %}
					<p class="kui-dialog__description" id="{{ _desc_id }}">{{ _description }}</p>
				{% endif %}
			</div>

			{# ── Body ─────────────────────────────────────────────────────── #}
			{% block dialog_body %}
			{% endblock %}

			{# ── Footer ───────────────────────────────────────────────────── #}
			{% block dialog_footer %}
			{% endblock %}

		</div>
	</dialog>
</div>
