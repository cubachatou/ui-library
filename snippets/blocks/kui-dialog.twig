{#
  kui-dialog.twig — Variant dispatcher.

  Reads the `style` field and delegates to the matching variant template.
  Project overrides: place a file at site/snippets/ui/kui-dialog_<style>.twig
  and it will be used automatically without modifying this plugin.
#}

{% set style = block.style.value ? : 'default' %}
{% include ['@ui/kui-dialog_' ~ style ~ '.twig', '@ui/kui-dialog_default.twig'] %}
