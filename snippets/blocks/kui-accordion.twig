{#
  kui-accordion.twig — Block entry point.

  Accordion uses a single template that covers all four built-in examples:
    Default   — one item open at a time (standard behaviour)
    Multiple  — allow_multiple_open toggle field
    Disabled  — disabled toggle on individual items
    Borders   — css_classes: accordion--bordered

  To add a project-level variant without modifying this plugin:
    1. Place your template at  site/snippets/ui/kui-accordion_myvariant.twig
    2. Use {% include ['@ui/kui-accordion_myvariant.twig', '@ui/kui-accordion_default.twig'] %}
    3. The @ui namespace searches site/snippets/ui/ first, then the plugin.
#}

{% include '@ui/kui-accordion_default.twig' %}
