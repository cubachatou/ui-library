{#
  select.twig — Block dispatcher.

  Reads the `style` field set in the Panel and delegates rendering to the
  correct variant template. Each variant independently embeds the shared base
  layout (_select_base.twig) and overrides only its own item_list block.

  Adding a new visual variant requires only:
    1. A new option value in blueprints/blocks/select.yml (style field).
    2. A new embed file in snippets/blocks/ (e.g. select_minimal.twig).
    3. A new branch in the conditional below.
  No changes to _select_base.twig, select.js, or _select.scss needed.
#}

{% set style = block.style.value %}

{% if style == 'grouped' %}
	{% include '@ui/select_grouped.twig' %}
{% else %}
	{% include '@ui/select_simple.twig' %}
{% endif %}
